# EarnIT frontend environment
# Copy to `.env.local` and fill in. All vars are client-exposed (NEXT_PUBLIC_*).

# Arc testnet RPC. Default: https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_RPC_URL=

# WalletConnect project id (required for mobile/QR wallets).
# Create one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Deployed contract addresses (Arc testnet defaults applied if left blank).
NEXT_PUBLIC_USDC_ADDRESS=0x491c9634670214E08208A607F8cA08adD3523205
NEXT_PUBLIC_USYC_ADDRESS=0x6cd4efb775217252543E6a9e42ccD50323727C36
NEXT_PUBLIC_TELLER_ADDRESS=0x1DC8C46DEF44C89dE572277ffe5Ea15c2C23B8Ef
NEXT_PUBLIC_FACTORY_ADDRESS=0x34bFd737C2073DCD2913f6bE344e0f626f24aa10
NEXT_PUBLIC_VAULT_ADDRESS=0x2F6470599C0Ee4E29C337C2C26f235a4EBBd6474
